[coding]
box-i ansible_host=box-i

# --- Fresh Hetzner box (root only on init) ---------------------------------
# Step 1 (once): create the dev user, connecting as root (use the PUBLIC ip):
#   scripts/bootstrap.sh --limit box1
# Step 2: provision as the dev user (still the public ip on the first run):
#   scripts/provision.sh --limit box1     # sign the node when it asks (tailnet lock)
# box1 ansible_host=1.2.3.4

# After the first provision, public SSH is closed — reach the box over tailscale,
# so switch ansible_host to its tailscale name for all future runs:
# box1 ansible_host=box1.<your-tailnet>.ts.net

# --- Skip tailscale on a host (keeps public SSH open) ----------------------
# box3 ansible_host=10.0.0.5 tailscale_enabled=false
